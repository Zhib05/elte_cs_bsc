        <mxCell id="oe1U5kva_cNWaiYP2Gws-9" value="filmNames := &amp;lt;&amp;gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;filmCounts := &amp;lt;&amp;gt;&lt;/span&gt;&lt;div&gt;&lt;b&gt;forall &lt;/b&gt;room &lt;b&gt;in &lt;/b&gt;rooms &lt;b&gt;loop&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;forall &lt;/b&gt;film&amp;nbsp;&lt;b&gt;in &lt;/b&gt;room.films&amp;nbsp;&lt;b&gt;loop&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;viewers :=&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-family: Symbol; font-size: 22px;&quot;&gt;S&lt;/font&gt;&lt;font style=&quot;font-size: 8.33333px;&quot;&gt;ticket in film.ickets&amp;nbsp;&lt;/font&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;1&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 11px; white-space: pre;&quot;&gt;&#x9;&amp;nbsp;&lt;/span&gt;&amp;nbsp;&amp;nbsp;&lt;sup style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 8px;&quot;&gt;ticket.Status == &quot;purchased&quot;&lt;/font&gt;&lt;/sup&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;b&gt;if &lt;/b&gt;film.FilmName &lt;b&gt;in &lt;/b&gt;filmNames &lt;b&gt;then &lt;/b&gt;index := filmNames.IndexOf(film.FilmName)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;b&gt;else &lt;/b&gt;filmNames.Add(film.FilmName), filmCounts.Add(viewers) &lt;b&gt;endif&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;/blockquote&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;endloop&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;endloop&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;( , mostViewedFilm) := &lt;b&gt;MAX&lt;/b&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;sub&gt;i&lt;/sub&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;sub style=&quot;&quot;&gt;&lt;font face=&quot;Symbol&quot;&gt;Î[0..&lt;/font&gt;|filmNames|]&lt;/sub&gt;filmCounts[i]&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;return &lt;/b&gt;mostViewedFilm&lt;/span&gt;&lt;/div&gt;&lt;p class=&quot;MsoNormal&quot;&gt;&lt;/p&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=13;align=left;fillColor=#fff2cc;strokeColor=#d6b656;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
