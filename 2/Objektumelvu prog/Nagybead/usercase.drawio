        </mxCell>
        <mxCell id="pZ73Nzw5i_hterST_Ri7-8" value="&lt;b&gt;forall &lt;/b&gt;room&amp;nbsp;&lt;b&gt;in &lt;/b&gt;rooms&amp;nbsp;&lt;b&gt;loop&lt;/b&gt;&lt;div&gt;&lt;b&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;forall &lt;/b&gt;film &lt;b&gt;in &lt;/b&gt;room.Films &lt;b&gt;loop&lt;/b&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;&lt;b&gt;if&lt;/b&gt;&amp;nbsp;film.FilmName&amp;nbsp;= filmName&amp;nbsp;&lt;b&gt;then return &lt;/b&gt;film&amp;nbsp;&lt;b&gt;endif&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;endloop&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;endloop&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;error&lt;/b&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=13;align=left;fillColor=#fff2cc;strokeColor=#d6b656;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
