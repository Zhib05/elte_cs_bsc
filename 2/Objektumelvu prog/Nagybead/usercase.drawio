        <mxCell id="oe1U5kva_cNWaiYP2Gws-6" value="&lt;b&gt;if &lt;/b&gt;ticket = null &lt;b&gt;then error endif&lt;/b&gt;&lt;div&gt;room := ticket.SecreeningRoom, viewer := ticket.Viewer, film := ticket.film&lt;/div&gt;&lt;div&gt;&lt;b&gt;if &lt;/b&gt;room.SeatAvailability(ticket.seatID) != &quot;Reserved&quot; &lt;b&gt;then error endif&lt;/b&gt;&lt;/div&gt;&lt;div&gt;film.RemoveTicket(ticket)&lt;/div&gt;&lt;div&gt;viewer.RemoveTicket(ticket)&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&lt;b&gt;forall&amp;nbsp;&lt;/b&gt;seat&amp;nbsp;&lt;b&gt;in&amp;nbsp;&lt;/b&gt;room.Seats&amp;nbsp;&lt;b&gt;loop&lt;/b&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&lt;span style=&quot;font-weight: bold; white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;if&amp;nbsp;&lt;/b&gt;seat.ID = ticket.SeatID&amp;nbsp;&lt;b&gt;then&amp;nbsp;&lt;/b&gt;seat.SetStatus(&quot;Available&quot;)&amp;nbsp;&lt;b&gt;endif&lt;/b&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&lt;b&gt;endloop&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=13;align=left;fillColor=#fff2cc;strokeColor=#d6b656;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
