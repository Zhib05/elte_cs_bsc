        <mxCell id="pZ73Nzw5i_hterST_Ri7-6" value="room := FindRoom(roomName)&lt;div&gt;film := FindFilm(filmName)&lt;/div&gt;&lt;div&gt;viewer := FindViewer(viewerID)&lt;/div&gt;&lt;div&gt;&lt;b&gt;if&lt;/b&gt;&amp;nbsp;room.SeatAvailability(seatID) != &quot;Available&quot;, room.SeatAvailability(seatID) != &quot;Reserved&quot;&amp;nbsp;&lt;b&gt;then error endif&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;ticket :=&amp;nbsp;&lt;b&gt;new&lt;/b&gt;&lt;/span&gt;&lt;b style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&amp;nbsp;&lt;/b&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;Ticket(seatID, &quot;Purchased&quot;, basePrice, room, viewer)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;film.AddTicket(ticket)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;viewer.AddTicket(ticket)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&lt;b&gt;forall &lt;/b&gt;seat &lt;b&gt;in &lt;/b&gt;room.Seats &lt;b&gt;loop&lt;/b&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&lt;span style=&quot;font-weight: bold; white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;if &lt;/b&gt;seat.ID = seatID &lt;b&gt;then &lt;/b&gt;seat.SetStatus(&quot;Purchased&quot;) &lt;b&gt;endif&lt;/b&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&lt;b&gt;endloop&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;p class=&quot;MsoNormal&quot;&gt;&lt;/p&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=13;align=left;fillColor=#fff2cc;strokeColor=#d6b656;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
          <mxGeometry x="2754" y="1092.5" width="580" height="155.5" as="geometry" />
        </mxCell>
        <mxCell id="pZ73Nzw5i_hterST_Ri7-7" value="&lt;b&gt;forall &lt;/b&gt;viewer&amp;nbsp;&lt;b&gt;in &lt;/b&gt;viewers&amp;nbsp;&lt;b&gt;loop&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;if&lt;/b&gt;&amp;nbsp;viewer.ID&amp;nbsp;= viewerID&amp;nbsp;&lt;b&gt;then return &lt;/b&gt;viewer&amp;nbsp;&lt;b&gt;endif&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;endloop&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;error&lt;/b&gt;&lt;br&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=13;align=left;fillColor=#fff2cc;strokeColor=#d6b656;" parent="WIyWlLk6GJQsqaUBKTNV-1" vertex="1">
